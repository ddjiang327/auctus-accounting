{
  "name": "auctus",
  "private": true,
  "version": "0.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:mobile": "npm run start -w apps/mobile",
    "dev:api": "npm run dev -w apps/api",
    "build": "npm run build:packages && npm run build:api && npm run build:web",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build:packages": "npm run build -w packages/shared-types && npm run build -w packages/accounting-core",
    "audit:pretrial": "node scripts/pretrial-audit.mjs",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
